# Copia este archivo a .env para desarrollo local
# En producción (Render), configura estas variables en el dashboard

# Base de datos PostgreSQL (Neon, Render, local, etc.)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/clinica_fisioterapia_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=tu_password_aqui

# JWT — genera un secreto seguro (mínimo 32 caracteres)
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_al_menos_32_chars
JWT_EXPIRATION=1800000
JWT_REFRESH_EXPIRATION=604800000
